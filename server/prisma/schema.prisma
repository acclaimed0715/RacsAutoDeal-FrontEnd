// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id           String   @id @default(cuid())
  name         String
  price        String
  promoPrice   String?
  modelYear    String
  mileage      String
  brand        String
  transmission String
  fuelType     String
  engine       String
  hp           String
  torque       String
  safety       String
  seating      String
  description  String   @db.Text
  status       String   // 'open' | 'in-progress' | 'closed' | 'pending_deal' | 'sold'
  images       Json     // Array of image data URLs
  date         String
  type         String?
  isArchived   Boolean  @default(false)
  saleReportedBy String? // Staff ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Staff {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // 'SUPER_ADMIN' | 'INVENTORY_MANAGER'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserReport {
  id          String   @id @default(cuid())
  userName    String
  userEmail   String
  reason      String
  description String?  @db.Text
  date        String
  status      String   // 'PENDING' | 'RESOLVED'
  createdAt   DateTime @default(now())
}

model AppSettings {
  id             Int      @id @default(1)
  businessName   String
  contactEmail   String
  phone          String
  address        String
  adminPassword  String?
  sessionTimeout Int
  emailNotif     Boolean
  stockNotif     Boolean
  theme          String   // 'dark' | 'light' | 'luxury'
  currency       String
  vehicleTypes   Json     // Array of strings
  updatedAt      DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @default(cuid())
  title     String
  message   String
  time      String
  type      String   // 'info' | 'success' | 'warning' | 'error'
  isRead    Boolean  @default(false)
  sender    String
  createdAt DateTime @default(now())
}
